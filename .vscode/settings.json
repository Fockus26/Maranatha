{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
        "source.fixAll.biome": "always",
        "source.organizeImports.biome": "always"
    },

    "js/ts.preferences.importModuleSpecifier": "non-relative",
    "js/ts.preferences.preferTypeOnlyAutoImports": true,

    "todo-tree.general.tags": ["TODO", "FIX", "DONE"],

    "todo-tree.highlights.enabled": true,

    "todo-tree.highlights.customHighlight": {
        "DONE": {
            "icon": "check",
            "type": "whole-line",
            "foreground": "#15152b",
            "background": "#60ee79",
            "iconColour": "#60ee79",
            "fontWeight": "bold",
            "borderRadius": "8px",
            "gutterIcon": true
        },
        "TODO": {
            "icon": "check",
            "type": "whole-line",
            "foreground": "#ffffff",
            "background": "#2563eb",
            "iconColour": "#2563eb",
            "fontWeight": "bold",
            "borderRadius": "8px",
            "gutterIcon": true
        },

        "FIX": {
            "icon": "flame",
            "type": "whole-line",
            "foreground": "#ffffff",
            "background": "#dc2626",
            "iconColour": "#dc2626",
            "fontWeight": "bold",
            "borderRadius": "8px",
            "gutterIcon": true
        }
    },

    "todo-tree.tree.hideTreeWhenEmpty": true,
    "todo-tree.tree.showCountsInTree": true
}
